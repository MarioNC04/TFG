# Variables de entorno para el Detector de Voz
# Copia este archivo a .env y modifica los valores según tu configuración

# ===========================================
# CONFIGURACIÓN DE GOOGLE CLOUD SPEECH API
# ===========================================

# Ruta al archivo de credenciales JSON de Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-cloud-key.json

# ID del proyecto de Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your-project-id-here

# ===========================================
# CONFIGURACIÓN DE AUDIO
# ===========================================

# Dispositivo de audio (específico para Raspberry Pi)
AUDIO_DEVICE=plughw:1,0

# Frecuencia de muestreo (Hz)
SAMPLE_RATE=16000

# Número de canales de audio
AUDIO_CHANNELS=1

# ===========================================
# CONFIGURACIÓN DE DETECCIÓN
# ===========================================

# Palabra clave a detectar
TARGET_WORD=voluntario

# Mensaje de respuesta
RESPONSE_MESSAGE=Hola mundo

# Idioma para reconocimiento de voz
LANGUAGE=es-ES

# Habilitar respuesta por voz (true/false)
ENABLE_VOICE_RESPONSE=true

# Usar Google Speech API (true) o reconocimiento local (false)
USE_GOOGLE_SPEECH=true

# ===========================================
# CONFIGURACIÓN DE AULA/ENTORNO
# ===========================================

# Nombre/ID del aula donde está instalado
CLASSROOM_ID=Aula-101

# Nombre del centro educativo
SCHOOL_NAME=Centro Educativo Ejemplo

# Ubicación física del dispositivo
DEVICE_LOCATION=Aula de Ciencias

# ===========================================
# CONFIGURACIÓN DE LOGGING
# ===========================================

# Habilitar logging remoto (true/false)
ENABLE_REMOTE_LOGGING=false

# URL del servidor para enviar logs
REMOTE_SERVER_URL=https://your-school-server.com/api/detections

# Clave API para el servidor remoto
API_KEY=your-api-key-here

# Nivel de logging (debug, info, warn, error)
LOG_LEVEL=info

# ===========================================
# CONFIGURACIÓN DE RASPBERRY PI
# ===========================================

# Optimizar para Raspberry Pi (true/false)
OPTIMIZE_FOR_RPI=true

# Tamaño de buffer de audio
BUFFER_SIZE=1024

# Máximo número de procesos concurrentes
MAX_CONCURRENT_PROCESSING=2

# ===========================================
# CONFIGURACIÓN DE SÍNTESIS DE VOZ
# ===========================================

# Motor de voz (espeak, festival, etc.)
TTS_VOICE=espeak-es

# Velocidad de habla
TTS_SPEED=150

# Volumen de voz (0.0 - 1.0)
TTS_VOLUME=0.8

# ===========================================
# CONFIGURACIÓN DE RED
# ===========================================

# Puerto para servidor web de monitoreo (opcional)
WEB_PORT=3000

# Interfaz de red para servidor web
WEB_INTERFACE=0.0.0.0

# Timeout para conexiones de red (ms)
NETWORK_TIMEOUT=5000